# Google Custom Search API
# 1. Create API key: https://console.cloud.google.com → APIs & Services → Credentials
#    Restrict key to "Custom Search API"
# 2. Create Search Engine: https://programmablesearchengine.google.com
#    Set to "Search the entire web" — copy the Search Engine ID (cx)
GOOGLE_CSE_API_KEY=your_api_key_here
GOOGLE_CSE_CX=your_search_engine_id_here
