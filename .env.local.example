# AI Match MVP
# Brave Search API key: https://api.search.brave.com/
BRAVE_SEARCH_API_KEY=your_brave_search_api_key_here

# OpenAI API key for ranking results
OPENAI_API_KEY=your_openai_api_key_here

# Optional model override (default: gpt-4.1-mini)
OPENAI_MODEL=gpt-4.1-mini

# Kill switch for public AI matching (set to false to disable)
AI_MATCH_ENABLED=true
