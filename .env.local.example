# AI Match MVP
# Search provider: google-serpapi | google-cse | tavily
SEARCH_PROVIDER=google-serpapi

# Google via SerpAPI (recommended for Google-like ranking quality)
SERPAPI_API_KEY=your_serpapi_api_key_here

# Google Custom Search (optional alternative provider/fallback)
GOOGLE_CSE_API_KEY=your_google_cse_api_key_here
GOOGLE_CSE_CX=your_google_cse_cx_here

# Tavily (optional provider/fallback)
TAVILY_API_KEY=your_tavily_api_key_here

# OpenAI API key for ranking results
OPENAI_API_KEY=your_openai_api_key_here

# Optional model override (default: gpt-4.1-mini)
OPENAI_MODEL=gpt-4.1-mini

# Kill switch for public AI matching (set to false to disable)
AI_MATCH_ENABLED=true
